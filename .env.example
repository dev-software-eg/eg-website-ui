SANITY_PROJECT_ID=
SANITY_DATASET=
# SANITY_TOKEN: only needed locally against the private "development" dataset.
# Use a Viewer (read-only) token from manage.sanity.io. Leave unset for production
# (public "production" dataset needs no token).
SANITY_TOKEN=

# URL of the separate ai-search-api backend this app proxies chat/search requests to.
# Must include the protocol (https://...), server-side fetch won't infer one.
# Next's own dev server also defaults to :3000 — use a different port here or
# /api/* will proxy into itself.
AI_SEARCH_API_URL=
# Only needed if AI_SEARCH_API_URL points at a Vercel deployment with Deployment
# Protection enabled (e.g. a preview branch). Generate under that project's
# Settings -> Deployment Protection -> Protection Bypass for Automation.
AI_SEARCH_API_BYPASS_SECRET=

# EmailJS service/template/public key for sending emails from the contact form.
# Keys found at https://dashboard.emailjs.com/ user login is dev-software@estiponagroup.com
NEXT_PUBLIC_EMAILJS_SERVICE_ID=
NEXT_PUBLIC_EMAILJS_TEMPLATE_ID=
NEXT_PUBLIC_EMAILJS_PUBLIC_KEY=
